{
  "name": "pr-reviewer",
  "version": "0.2.0",
  "description": "Read-only SDD-aware pull/merge request reviewer exposed through MCP.",
  "type": "module",
  "private": true,
  "bin": {
    "pr-reviewer": "./src/main.ts"
  },
  "scripts": {
    "mcp": "bun --no-env-file src/main.ts mcp",
    "doctor": "bun --no-env-file src/main.ts doctor",
    "version": "bun --no-env-file src/main.ts --version",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bun test tests/unit tests/contract tests/security",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "build": "bun scripts/build.ts",
    "verify:artifact": "bun scripts/verify-artifact.ts",
    "check": "bun run typecheck && bun run lint && bun test && bun run test:integration && bun run test:e2e && bun run build && bun run verify:artifact"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.111.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  }
}
